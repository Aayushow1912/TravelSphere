AVIATIONSTACK_API_KEY=your_aviationstack_api_key
GROQ_API_KEY=your_groq_api_key
TAVILY_API_KEY=your_tavily_api_key
DATABASE_URL=postgresql://postgres:password@localhost:5432/langgraph_memory
OPENWEATHER_API_KEY=your_openweather_api_key

# Disabled by default for Streamlit Cloud friendliness.
# Set to true only when DATABASE_URL points to a reachable Postgres database.
USE_POSTGRES_CHECKPOINTER=false

# Optional: override the Python executable used to run the aviation MCP server.
# AVIATION_MCP_PYTHON=aviationstack-mcp/.venv/Scripts/python.exe

# Optional: override the local weather MCP server script path.
# WEATHER_MCP_SCRIPT=weather_mcp_server.py
